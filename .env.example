# База данных
# SQLite по умолчанию. Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/parser
# DATABASE_URL=

# Парсинг
CONCURRENCY=5
DELAY_MIN=8.0
DELAY_MAX=15.0
# SKIP_INITIAL_DELAY=true — без паузы 8–15 сек перед запросом (для тестов)
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=2.0
PAGE_TIMEOUT_MS=30000

# Браузер
HEADLESS=true
# HEADLESS=false  — видимый браузер (при блокировке)

# Обход блокировок (Patchright + Chrome рекомендуется)
# CHROME_BINARY_PATH=/usr/bin/chromium  — путь к Chrome в Docker
# PROXY_URL=http://user:password@proxy.example.com:8080
# PROXY_URL=socks5://user:password@proxy.example.com:1080

# Camoufox (рекомендуется при блокировках fedresurs/kad.arbitr)
USE_CAMOUFOX_PARSER=false

# Tor + FlareSolverr + undetected-chromedriver (fedresurs.ru)
USE_TOR_PARSER=true
TOR_PROXY=socks5://127.0.0.1:9050
TOR_CONTROL_PORT=9051
FLARESOLVERR_URL=http://localhost:8191/v1

# xlsx
XLSX_SHEET_NAME=Sheet1
XLSX_INN_COLUMN=ИНН
