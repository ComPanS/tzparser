# База данных
# SQLite по умолчанию. Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/parser
# DATABASE_URL=

# Парсинг
CONCURRENCY=5
DELAY_MIN=8.0
DELAY_MAX=15.0
# SKIP_INITIAL_DELAY=true — без паузы 8–15 сек перед запросом (для тестов)
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=2.0
PAGE_TIMEOUT_MS=60000

# Браузер (Camoufox)
HEADLESS=true
# HEADLESS=false — видимый браузер (при блокировке)

# Прокси
# PROXY_URL=http://user:password@proxy.example.com:8080
# PROXY_URL=socks5://user:password@proxy.example.com:1080

# xlsx
XLSX_SHEET_NAME=Sheet1
XLSX_INN_COLUMN=ИНН
